{
  "id": "codex-sandbox",
  "version": "1.1.0",
  "name": "Codex Sandbox",
  "description": "Hardened Debian dev container with OpenAI Codex CLI, CodeGraph (wired to Codex), and frontend (Vue/React/Tailwind) VS Code extensions.",
  "documentationURL": "https://github.com/OrangeKing-Leo/coding-agent-dev-container/tree/main/templates/src/codex-sandbox",
  "options": {
    "nodeVersion": {
      "type": "string",
      "proposals": ["22", "20", "18"],
      "default": "20",
      "description": "Major Node.js version installed by the CLI features."
    },
    "codexVersion": {
      "type": "string",
      "proposals": ["latest"],
      "default": "latest",
      "description": "Version of @openai/codex (npm dist-tag or semver)."
    },
    "codegraphVersion": {
      "type": "string",
      "proposals": ["latest"],
      "default": "latest",
      "description": "Version of @colbymchenry/codegraph (npm dist-tag or semver)."
    }
  },
  "platforms": ["debian"],
  "publisher": "OrangeKing-Leo",
  "keywords": ["codex", "codegraph", "sandbox", "frontend", "vue", "react"]
}
